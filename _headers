# Cloudflare Pages headers — cache & security
# Place this file in the root of your deployment directory.
# Cloudflare Pages auto-detects _headers on deploy.

# App shell (immutable, cache aggressively)
/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

# HTML (validate quickly)
/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Manifest & service worker (validate quickly)
/manifest.json
  Cache-Control: public, max-age=0, must-revalidate

/sw.js
  Cache-Control: public, max-age=0, must-revalidate

# Security headers
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: microphone=(), camera=(), geolocation=()
