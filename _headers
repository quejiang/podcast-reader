# Cloudflare Pages headers — cache & security
# Place this file in the root of your deployment directory.
# Cloudflare Pages auto-detects _headers on deploy.

# JS/CSS: 5-min CDN cache + stale-while-revalidate (24h).
# Users get latest code within 5 min; old version serves as fallback.
/css/*
  Cache-Control: public, max-age=300, stale-while-revalidate=86400

/js/*
  Cache-Control: public, max-age=300, stale-while-revalidate=86400

# HTML (validate quickly)
/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Manifest & service worker (validate quickly)
/manifest.json
  Cache-Control: public, max-age=0, must-revalidate

/sw.js
  Cache-Control: public, max-age=0, must-revalidate

# Security headers
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: microphone=(), camera=(), geolocation=()
